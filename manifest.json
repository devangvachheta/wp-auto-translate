{
  "manifest_version": 3,
  "name": "WP Auto Translator",
  "version": "1.0.0",
  "description": "WordPress GlotPress auto translation - 45+ languages",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "WP Auto Translator"
  },
  "content_scripts": [
    {
      "matches": ["https://translate.wordpress.org/*"],
      "js": ["content.js"]
    }
  ],
  "permissions": ["activeTab"]
}
